<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/rootLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_deep"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="24dp"
        android:paddingVertical="40dp">

        <!-- Logo / Hero -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginBottom="40dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⚡"
                android:textSize="64sp"
                android:gravity="center" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="FreeDrama\nAd Skipper"
                android:textSize="32sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:fontFamily="sans-serif-medium"
                android:gravity="center"
                android:layout_marginTop="12dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Auto-skips every ad. Zero delay."
                android:textSize="14sp"
                android:textColor="@color/text_secondary"
                android:gravity="center"
                android:layout_marginTop="8dp" />
        </LinearLayout>

        <!-- Step 1: Overlay -->
        <LinearLayout
            android:id="@+id/stepOverlay"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_glass"
            android:padding="20dp"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Step 1"
                    android:textSize="11sp"
                    android:textColor="@color/accent_violet"
                    android:textAllCaps="true"
                    android:letterSpacing="0.1" />

                <ImageView
                    android:id="@+id/checkOverlay"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_check"
                    android:visibility="gone" />
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Overlay Permission"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:layout_marginTop="4dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Required for the floating control panel to appear on top of FreeDrama."
                android:textSize="13sp"
                android:textColor="@color/text_secondary"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="14dp" />

            <Button
                android:id="@+id/btnGrantOverlay"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="Grant Overlay"
                android:backgroundTint="@color/accent_violet"
                android:textColor="@color/text_primary"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Step 2: Screen Capture -->
        <LinearLayout
            android:id="@+id/stepScreenCapture"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_glass"
            android:padding="20dp"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Step 2"
                    android:textSize="11sp"
                    android:textColor="@color/accent_cyan"
                    android:textAllCaps="true"
                    android:letterSpacing="0.1" />

                <ImageView
                    android:id="@+id/checkCapture"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_check"
                    android:visibility="gone" />
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Screen Capture"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:layout_marginTop="4dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Allows the app to read your screen to detect Skip Ad buttons. Done once per session."
                android:textSize="13sp"
                android:textColor="@color/text_secondary"
                android:layout_marginTop="6dp" />

            <TextView
                android:id="@+id/tvCaptureStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Tap button → system dialog aayega → 'Start Now' dabao"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="14dp"
                android:fontFamily="monospace" />

            <Button
                android:id="@+id/btnGrantCapture"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="Grant Screen Capture"
                android:backgroundTint="@color/accent_cyan"
                android:textColor="@color/bg_deep"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Step 3: Accessibility -->
        <LinearLayout
            android:id="@+id/stepAccessibility"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_glass"
            android:padding="20dp"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Step 3"
                    android:textSize="11sp"
                    android:textColor="@color/accent_green"
                    android:textAllCaps="true"
                    android:letterSpacing="0.1" />

                <ImageView
                    android:id="@+id/checkAccess"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_check"
                    android:visibility="gone" />
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Accessibility Service"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:layout_marginTop="4dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Enables the app to tap the Skip Ad button. Enable 'FreeDrama Ad Skipper' in Accessibility Settings."
                android:textSize="13sp"
                android:textColor="@color/text_secondary"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="14dp" />

            <Button
                android:id="@+id/btnGrantAccessibility"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="Enable Accessibility"
                android:backgroundTint="@color/accent_green"
                android:textColor="@color/bg_deep"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Ready Step -->
        <LinearLayout
            android:id="@+id/stepReady"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_ready"
            android:padding="20dp"
            android:gravity="center"
            android:layout_marginBottom="24dp"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🎉 All Set!"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:gravity="center" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tap below to launch the floating panel and start skipping ads."
                android:textSize="13sp"
                android:textColor="@color/text_secondary"
                android:gravity="center"
                android:layout_marginTop="8dp" />
        </LinearLayout>

        <!-- Launch Button -->
        <Button
            android:id="@+id/btnLaunchService"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="🚀  Launch Ad Skipper"
            android:textSize="16sp"
            android:textStyle="bold"
            android:backgroundTint="@color/accent_violet"
            android:textColor="@color/text_primary"
            android:enabled="false"
            android:alpha="0.5" />

    </LinearLayout>
</ScrollView>
